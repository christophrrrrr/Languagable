# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# Postgres connection string. Works with Neon, Supabase, or local Postgres.
# Neon: use the DIRECT connection string (toggle "Pooled connection" OFF in the
# Neon dashboard). It ends with ?sslmode=require, e.g.
#   postgresql://<user>:<password>@ep-xxx.<region>.aws.neon.tech/<db>?sslmode=require
# Local Postgres example:
#   postgresql://postgres:postgres@localhost:5432/languagable
DATABASE_URL=""

# --- AI (provider-agnostic via the Vercel AI SDK) ---
# Provider: "google" | "anthropic" | "openai"
AI_PROVIDER="google"

# Model IDs. Conversation = fast/cheap; Analysis = stronger.
# gemini-2.5-flash works for both. For stronger analysis set AI_ANALYSIS_MODEL
# to gemini-2.5-pro. (Check available models for your key; some older IDs like
# gemini-2.0-flash are deprecated.)
AI_CONVERSATION_MODEL="gemini-2.5-flash"
AI_ANALYSIS_MODEL="gemini-2.5-flash"

# Set the key matching AI_PROVIDER.
# Google AI Studio key (free): https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Target Spanish variety. Currently only "peninsular" is supported.
SPANISH_VARIETY="peninsular"
